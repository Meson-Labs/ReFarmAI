<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Mortgage Corner</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="styles.css">
    <script src="app.js" defer></script>
</head>
<body class="bg-gray-100 font-sans h-screen flex flex-col items-center justify-center overflow-hidden">

    <div id="login-section" class="w-full max-w-md bg-white shadow-xl rounded-lg overflow-hidden p-8">
        <div class="text-center mb-6">
            <h1 class="text-2xl font-bold text-blue-600">Welcome Back</h1>
            <p class="text-gray-500">Please sign in to access the Mortgage Assistant.</p>
        </div>
        
        <form id="login-form" class="space-y-4">
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2" for="username">Username</label>
                <input type="text" id="username" class="w-full border p-2 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>
            <div>
                <label class="block text-gray-700 text-sm font-bold mb-2" for="password">Password</label>
                <input type="password" id="password" class="w-full border p-2 rounded focus:outline-none focus:ring-2 focus:ring-blue-500" required>
            </div>
            <div id="login-error" class="text-red-500 text-sm hidden">Invalid credentials. Please try again.</div>
            <button type="submit" class="w-full bg-blue-600 text-white font-bold py-2 px-4 rounded hover:bg-blue-700 transition duration-200">
                Sign In
            </button>
        </form>
    </div>

    <div id="chat-section" class="w-full h-screen hidden flex overflow-hidden">
        
        <div id="sidebar" class="w-64 bg-gray-900 text-white flex flex-col transition-all duration-300 transform -translate-x-full md:translate-x-0 absolute md:relative z-20 h-full shadow-xl">
            <div class="p-4 border-b border-gray-700 flex justify-between items-center bg-gray-800">
                <h2 class="font-bold text-lg">History</h2>
                <button id="close-sidebar-btn" class="md:hidden text-gray-400 hover:text-white">✕</button>
            </div>
            
            <div id="history-list" class="flex-1 overflow-y-auto p-2 space-y-1">
                </div>
            
            <div class="p-4 border-t border-gray-700 bg-gray-800">
                 <button id="logout-btn" class="w-full bg-red-600 hover:bg-red-700 text-white py-2 rounded transition text-sm font-semibold shadow">Logout</button>
            </div>
        </div>

        <div class="flex-1 flex flex-col h-full relative w-full">
            
            <div class="bg-blue-600 p-4 text-white flex justify-between items-center shadow-md z-10">
                <div class="flex items-center gap-3">
                    <button id="toggle-sidebar-btn" class="md:hidden text-white text-xl">☰</button>
                    <h1 class="font-bold text-lg">Mortgage Assistant</h1>
                </div>
                <div class="flex gap-3 text-xs items-center">
                    <span id="session-badge" class="bg-blue-800 px-2 py-1 rounded hidden md:inline font-mono opacity-80"></span>
                    
                    <button id="new-chat-btn" class="bg-white text-blue-600 hover:bg-gray-100 px-3 py-1 rounded transition font-bold shadow-sm">
                        + New Chat
                    </button>
                </div>
            </div>

            <div id="chat-container" class="flex-1 p-4 overflow-y-auto space-y-4 bg-gray-50 flex flex-col pb-20">
                <div class="bg-white text-gray-800 p-3 rounded-lg self-start max-w-[80%] border border-gray-200 chat-message shadow-sm">
                    Hi there! I am here to help with your mortgage queries.
                </div>
            </div>

            <div class="p-4 border-t bg-white w-full">
                <div class="flex gap-2 items-center">
                    <input type="file" id="file-input" class="hidden">
                    <button id="upload-btn" class="bg-gray-200 p-2 rounded-full hover:bg-gray-300 transition w-10 h-10 flex items-center justify-center text-gray-600 shadow-sm">📎</button>
                    
                    <button id="mic-btn" class="bg-gray-200 p-2 rounded-full hover:bg-gray-300 transition w-10 h-10 flex items-center justify-center text-gray-600 border border-gray-300 shadow-sm">🎤</button>
                    
                    <input type="text" id="user-input" class="flex-1 border p-2 rounded-lg focus:outline-none focus:ring-2 focus:ring-blue-500 shadow-inner" placeholder="Type or click mic to speak...">
                    <button id="send-btn" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 transition font-semibold shadow-md">Send</button>
                </div>
                <div class="flex justify-between mt-2 px-1">
                    <div id="status" class="text-xs text-gray-500">Connected</div>
                    <div id="voice-status" class="text-xs font-bold text-red-500 hidden animate-pulse flex items-center gap-1">
                        <span>●</span> Live Voice Active
                    </div>
                </div>
            </div>

        </div>
    </div>
</body>
</html>